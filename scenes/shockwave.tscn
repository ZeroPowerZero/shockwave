[sub_resource type="Shader" id="Shader_wvvyk"]
code = "shader_type spatial;
	render_mode unshaded, cull_disabled, depth_draw_never, shadows_disabled;
	
	uniform sampler2D screen_texture : hint_screen_texture, filter_linear_mipmap;
	uniform float strength = 0.08;
	uniform float thickness = 0.15;
	
	void vertex() {
		mat4 modified_model_view = VIEW_MATRIX * mat4(
			INV_VIEW_MATRIX[0] * length(MODEL_MATRIX[0].xyz),
			INV_VIEW_MATRIX[1] * length(MODEL_MATRIX[1].xyz),
			INV_VIEW_MATRIX[2] * length(MODEL_MATRIX[2].xyz),
			MODEL_MATRIX[3]
		);
		MODELVIEW_MATRIX = modified_model_view;
		MODELVIEW_NORMAL_MATRIX = mat3(MODELVIEW_MATRIX);
	}
	
	void fragment() {
		vec2 uv = UV - vec2(0.5);
		float dist = length(uv);
		float circle = smoothstep(0.5, 0.49, dist);
		float ring = smoothstep(0.5, 0.5 - thickness, dist) * smoothstep(0.5 - thickness * 2.0, 0.5 - thickness, dist);
		vec2 offset = normalize(uv) * ring * strength * COLOR.a;
		ALBEDO = texture(screen_texture, SCREEN_UV - offset).rgb;
		ALPHA = circle;
	}"

